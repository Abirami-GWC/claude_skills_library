{
  "signal_categories": [
    {
      "category": "company_events",
      "examples": ["funding round", "product launch", "leadership change", "acquisition", "office expansion"],
      "use_in_touch": [1, 2],
      "verification_required": true
    },
    {
      "category": "hiring_signals",
      "examples": ["open roles matching pain point", "team scaling in relevant function"],
      "use_in_touch": [1, 3],
      "verification_required": true
    },
    {
      "category": "content_signals",
      "examples": ["exec published article/podcast appearance", "company blog post", "conference talk"],
      "use_in_touch": [1, 2, 3],
      "verification_required": true
    },
    {
      "category": "tech_stack_signals",
      "examples": ["tools detected via job postings or public stack", "integration gaps"],
      "use_in_touch": [1, 2],
      "verification_required": true
    },
    {
      "category": "engagement_signals",
      "examples": ["content download", "webinar attendance", "website visit", "email open pattern"],
      "use_in_touch": [1],
      "verification_required": false,
      "note": "First-party data provided by user; generally safe to use directly."
    },
    {
      "category": "peer_signals",
      "examples": ["competitor adoption", "industry peer using similar solution"],
      "use_in_touch": [3, 4],
      "verification_required": true
    },
    {
      "category": "role_signals",
      "examples": ["persona's likely KPIs", "typical pain points for this title/function"],
      "use_in_touch": [1, 2, 3],
      "verification_required": false,
      "note": "General role-based reasoning is acceptable without company-specific verification, but should not be presented as if specific to the individual."
    }
  ],
  "rules": {
    "verification_required_true": "Do not state as fact unless confirmed by user-supplied research or a research tool. Otherwise use placeholder syntax: [VERIFY: <claim>].",
    "never_use": ["invented dollar figures", "invented executive names", "invented press coverage"]
  }
}
